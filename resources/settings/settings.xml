<?xml version="1.0" encoding="UTF-8"?>
<settings>
    <setting
        propertyKey="@Properties.InhaleSeconds"
        title="@Strings.InhaleSecondsTitle"
        prompt="@Strings.DurationPrompt">
        <settingConfig
            type="numeric"
            min="1"
            max="30"
            required="true"
            errorMessage="@Strings.DurationError"/>
    </setting>

    <setting
        propertyKey="@Properties.ExhaleSeconds"
        title="@Strings.ExhaleSecondsTitle"
        prompt="@Strings.DurationPrompt">
        <settingConfig
            type="numeric"
            min="1"
            max="30"
            required="true"
            errorMessage="@Strings.DurationError"/>
    </setting>

    <setting propertyKey="@Properties.CircleColor" title="@Strings.CircleColorTitle">
        <settingConfig type="list">
            <listEntry value="0x00AAFF">@Strings.ColorBlue</listEntry>
            <listEntry value="0x00FF00">@Strings.ColorGreen</listEntry>
            <listEntry value="0xFFAA00">@Strings.ColorYellow</listEntry>
            <listEntry value="0xFF5500">@Strings.ColorOrange</listEntry>
            <listEntry value="0xFF0000">@Strings.ColorRed</listEntry>
            <listEntry value="0xAA00FF">@Strings.ColorPurple</listEntry>
            <listEntry value="0xFF00FF">@Strings.ColorPink</listEntry>
            <listEntry value="0xFFFFFF">@Strings.ColorWhite</listEntry>
        </settingConfig>
    </setting>
</settings>
